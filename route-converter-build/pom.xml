<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <artifactId>route-converter-build</artifactId>
    <packaging>pom</packaging>
    <name>The build parent module</name>
    <parent>
        <groupId>slash.navigation</groupId>
        <artifactId>RouteConverter</artifactId>
        <version>3.5-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <pluginRepositories>
        <pluginRepository>
            <id>oss-sonatype-snapshots</id>
            <url>https://oss.sonatype.org/content/groups/public/</url>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </pluginRepository>
    </pluginRepositories>
    
    <properties>
        <maven.build.timestamp.format>yyyy-MM-dd HH:mm:ss</maven.build.timestamp.format>
        <!-- workaround for https://issues.apache.org/jira/browse/MASSEMBLY-603 -->
        <maven.build.timestamp.clone>${maven.build.timestamp}</maven.build.timestamp.clone>
        <!-- Single source of truth for the bundled Temurin JDK / jlinked JRE
             patch version. Consumed by RouteConverterWindowsBundle and
             TimeAlbumProWindowsBundle (via NSI resource filtering,
             ${jre.version}), and the build-windows-jre / prerelease /
             release GitHub workflows (grep on this pom). -->
        <jre.version>17.0.15</jre.version>
   </properties>

    <build>
        <plugins>
            <!-- buildnumber-maven-plugin removed 2026-06-07: previously read
                 buildNumber0 from buildNumber.properties on disk and required
                 a `git checkout` of that file after every mvn release:prepare
                 invocation. ${maven.build.number} is now set at mvn invocation
                 time by the GitHub Actions workflows via
                 -Dmaven.build.number=${{ github.run_number }}; root pom
                 declares a 0 fallback for local builds. -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <phase>validate</phase>
                        <goals>
                            <goal>parse-version</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>current-year</id>
                        <phase>validate</phase>
                        <goals>
                            <goal>timestamp-property</goal>
                        </goals>
                        <configuration>
                            <name>current.year</name>
                            <pattern>yyyy</pattern>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <dependencies>
        <dependency>
            <groupId>${project.groupId}</groupId>
            <artifactId>route-converter-license</artifactId>
            <version>${project.version}</version>
        </dependency>
    </dependencies>
</project>
